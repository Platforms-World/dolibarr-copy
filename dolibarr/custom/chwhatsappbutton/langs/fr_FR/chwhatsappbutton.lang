# Default Templates
Template_THIRDPARTY_DEFAULT_Label = Message général au tiers
Template_THIRDPARTY_DEFAULT_Desc = Modèle par défaut pour les tiers
Template_THIRDPARTY_DEFAULT_Message = Bonjour __THIRDPARTY_NAME__,\n\nNous espérons que tout va bien.\n\nCordialement.

Template_PROJECT_UPDATE_Label = Mise à jour du projet
Template_PROJECT_UPDATE_Desc = Notifier l'avancement du projet
Template_PROJECT_UPDATE_Message = Bonjour __THIRDPARTY_NAME__,\n\nJe vous écris au sujet du projet : __PROJECT_REF__ - __PROJECT_TITLE__\n\n[Écrivez votre message ici]\n\nCordialement.

Template_PROPAL_SEND_Label = Envoi de proposition commerciale
Template_PROPAL_SEND_Desc = Notifier l'envoi de la proposition
Template_PROPAL_SEND_Message = Bonjour __THIRDPARTY_NAME__,\n\nNous vous avons envoyé la proposition commerciale __PROPAL_REF__ pour un montant de __PROPAL_TOTAL_TTC__.\n\nNous restons à votre disposition pour toute question.\n\nCordialement.

Template_INVOICE_SEND_Label = Envoi de facture
Template_INVOICE_SEND_Desc = Notifier l'envoi de la facture
Template_INVOICE_SEND_Message = Bonjour __THIRDPARTY_NAME__,\n\nNous vous informons que la facture __INVOICE_REF__ pour un montant de __INVOICE_TOTAL_TTC__ est disponible.\n\nMerci pour votre confiance.\n\nCordialement.

Template_PAYMENT_REMINDER_Label = Rappel de paiement
Template_PAYMENT_REMINDER_Desc = Rappeler un paiement en attente
Template_PAYMENT_REMINDER_Message = Bonjour __THIRDPARTY_NAME__,\n\nNous vous rappelons que la facture __INVOICE_REF__ pour __INVOICE_TOTAL_TTC__ est en attente de paiement.\n\nSi vous avez déjà effectué le paiement, veuillez ignorer ce message.\n\nMerci.

Template_PROPAL_FOLLOWUP_Label = Suivi de proposition
Template_PROPAL_FOLLOWUP_Desc = Faire un suivi sur la proposition envoyée
Template_PROPAL_FOLLOWUP_Message = Bonjour __THIRDPARTY_NAME__,\n\nAvez-vous eu l'occasion de consulter la proposition __PROPAL_REF__ que nous vous avons envoyée ?\n\nNous sommes disponibles pour toute question ou clarification.\n\nCordialement.
