Template_THIRDPARTY_DEFAULT_Message = Salve __THIRDPARTY_NAME__,\n\nSperiamo che tutto vada bene.\n\nCordiali saluti.

Template_PROJECT_UPDATE_Label = Aggiornamento progetto
Template_PROJECT_UPDATE_Desc = Notificare i progressi del progetto
Template_PROJECT_UPDATE_Message = Salve __THIRDPARTY_NAME__,\n\nLe scrivo riguardo al progetto: __PROJECT_REF__ - __PROJECT_TITLE__\n\n[Scrivi il tuo messaggio qui]\n\nCordiali saluti.

Template_PROPAL_SEND_Label = Invio preventivo
Template_PROPAL_SEND_Desc = Notificare l'invio del preventivo
Template_PROPAL_SEND_Message = Salve __THIRDPARTY_NAME__,\n\nLe abbiamo inviato il preventivo __PROPAL_REF__ per un importo di __PROPAL_TOTAL_TTC__.\n\nRimaniamo a Sua disposizione per qualsiasi domanda.\n\nCordiali saluti.

Template_INVOICE_SEND_Label = Invio fattura
Template_INVOICE_SEND_Desc = Notificare l'invio della fattura
Template_INVOICE_SEND_Message = Salve __THIRDPARTY_NAME__,\n\nLa informiamo che la fattura __INVOICE_REF__ per un importo di __INVOICE_TOTAL_TTC__ è disponibile.\n\nGrazie per la Sua fiducia.\n\nCordiali saluti.

Template_PAYMENT_REMINDER_Label = Promemoria pagamento
Template_PAYMENT_REMINDER_Desc = Ricordare un pagamento in sospeso
Template_PAYMENT_REMINDER_Message = Salve __THIRDPARTY_NAME__,\n\nLe ricordiamo che la fattura __INVOICE_REF__ per __INVOICE_TOTAL_TTC__ è in attesa di pagamento.\n\nSe ha già effettuato il pagamento, La preghiamo di ignorare questo messaggio.\n\nGrazie.

Template_PROPAL_FOLLOWUP_Label = Seguito preventivo
Template_PROPAL_FOLLOWUP_Desc = Fare un seguito sul preventivo inviato
Template_PROPAL_FOLLOWUP_Message = Salve __THIRDPARTY_NAME__,\n\nHa avuto modo di esaminare il preventivo __PROPAL_REF__ che Le abbiamo inviato?\n\nSiamo disponibili per qualsiasi domanda o chiarimento.\n\nCordiali saluti.
