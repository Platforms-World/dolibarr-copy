Template_PROJECT_UPDATE_Label = Actualización de proyecto
Template_PROJECT_UPDATE_Desc = Notificar avances en proyecto
Template_PROJECT_UPDATE_Message = Hola __THIRDPARTY_NAME__,\n\nTe escribo sobre el proyecto: __PROJECT_REF__ - __PROJECT_TITLE__\n\n[Escribe tu mensaje aquí]\n\nSaludos.

Template_PROPAL_SEND_Label = Envío de presupuesto
Template_PROPAL_SEND_Desc = Notificar envío de presupuesto
Template_PROPAL_SEND_Message = Hola __THIRDPARTY_NAME__,\n\nTe hemos enviado el presupuesto __PROPAL_REF__ por un importe de __PROPAL_TOTAL_TTC__.\n\nQuedamos a tu disposición para cualquier consulta.\n\nSaludos.

Template_INVOICE_SEND_Label = Envío de factura
Template_INVOICE_SEND_Desc = Notificar envío de factura
Template_INVOICE_SEND_Message = Hola __THIRDPARTY_NAME__,\n\nTe informamos que la factura __INVOICE_REF__ por un importe de __INVOICE_TOTAL_TTC__ está disponible.\n\nGracias por tu confianza.\n\nSaludos.

Template_PAYMENT_REMINDER_Label = Recordatorio de pago
Template_PAYMENT_REMINDER_Desc = Recordar pago pendiente
Template_PAYMENT_REMINDER_Message = Hola __THIRDPARTY_NAME__,\n\nTe recordamos que la factura __INVOICE_REF__ por __INVOICE_TOTAL_TTC__ está pendiente de pago.\n\nSi ya has realizado el pago, por favor ignora este mensaje.\n\nGracias.

Template_PROPAL_FOLLOWUP_Label = Seguimiento de presupuesto
Template_PROPAL_FOLLOWUP_Desc = Hacer seguimiento de presupuesto enviado
Template_PROPAL_FOLLOWUP_Message = Hola __THIRDPARTY_NAME__,\n\n¿Has tenido oportunidad de revisar el presupuesto __PROPAL_REF__ que te enviamos?\n\nEstamos disponibles para cualquier duda o aclaración.\n\nSaludos.
